# ===========================================
# Support Knowledge Claw — Environment Config
# ===========================================

# REQUIRED: Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Optional: Model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Server config
HOST=0.0.0.0
PORT=8000

# Optional: Confidence threshold for escalation (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.75

# Optional: ChromaDB persist directory
CHROMA_PERSIST_DIR=./chroma_db

# Optional: SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./support_claw.db
